{
  "name": "@portixone/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "service:install": "node scripts/service.install.js",
    "service:uninstall": "node scripts/service.uninstall.js",
    "service:start": "net start \"PortixOne Runtime\"",
    "service:stop": "net stop \"PortixOne Runtime\"",
    "firewall:install": "node scripts/firewall.install.js",
    "firewall:uninstall": "node scripts/firewall.uninstall.js"
  },
  "dependencies": {
    "@portixone/escpos": "*",
    "@portixone/protocol": "*",
    "@portixone/shared": "*",
    "node-windows": "^1.0.0-beta.8",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
