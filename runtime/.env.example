PORTIX_RUNTIME_PORT=17321
PORTIX_RUNTIME_HOST=127.0.0.1
PORTIX_LOCAL_API_KEY=dev-local-key

# Printer driver: mock | network | windows-spooler
PORTIX_PRINTER_DRIVER=mock

# windows-spooler: exact name of the printer as shown by `Get-Printer` /
# Windows Settings > Printers. Can also be overridden per-request via
# print({ printerName }).
PORTIX_DEFAULT_PRINTER=

# network: host/port of an Ethernet/WiFi thermal printer's raw print port
# (9100 is the de facto standard on Epson, Xprinter, and most others).
PORTIX_NETWORK_PRINTER_HOST=
PORTIX_NETWORK_PRINTER_PORT=9100

# ── Licensing (all optional) ────────────────────────────────────────────────
# A runtime with none of these set is a development machine: it prints freely,
# unlicensed. Licensing NEVER gates printing — these only power production
# authorization, the Portal, and the local dashboard's posture badge.
#
# License environment. FAIL-CLOSED: anything other than "development" (including unset) is
# treated as production, which trusts ONLY the production keyring and refuses to start if a
# development signing key is present. Set to "development" for local licensing work so the dev
# signing key is accepted.
PORTIX_LICENSE_ENV=development
# The public Application ID (app_<slug>_<rand>) this runtime is deployed under.
PORTIX_APPLICATION_ID=
# portix-cloud's 12h token-renewal endpoint. Unset = the runtime rides its
# cached license token (offline grace) and never phones home.
PORTIX_LICENSE_HEARTBEAT_URL=
# portix-cloud's installation-registration endpoint, paired with a one-time
# installation token. Normally written into config by the installer, not by hand.
PORTIX_LICENSE_REGISTRATION_URL=
PORTIX_INSTALLATION_TOKEN=
