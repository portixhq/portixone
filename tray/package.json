{
  "name": "@portixone/tray",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight Windows system tray companion for the Portix Runtime — shows status, no Electron.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate-icon": "node scripts/generate-placeholder-icon.js"
  },
  "dependencies": {
    "@portixone/shared": "*",
    "systray2": "^2.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
