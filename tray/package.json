{
  "name": "@portixone/tray",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight Windows system tray companion for the Portix Runtime — shows status, no Electron.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate-icon": "node scripts/generate-icon.js"
  },
  "dependencies": {
    "@portixone/protocol": "*",
    "@portixone/shared": "*",
    "node-notifier": "^10.0.1",
    "systray2": "^2.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-notifier": "^8.0.5",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
